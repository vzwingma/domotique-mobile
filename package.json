{
  "name": "domoticz-mobile",
  "main": "expo-router/entry",
  "version": "4.1.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "postinstall": "node ./scripts/fix-vector-icons-fonts.js",
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "android:clean": "expo prebuild --platform android --clean && expo run:android",
    "android:clean:device": "expo prebuild --platform android --clean && expo run:android --device",
    "android:reinstall:device": "node -e \"const {spawnSync}=require('child_process');spawnSync('adb',['uninstall','io.github.vzwingma.domatique.mobile'],{stdio:'inherit'})\" && expo prebuild --platform android --clean && expo run:android --device",
    "android:logs": "adb logcat -s ReactNativeJS:V NetworkSecurityConfig:V CONSCRYPT:W",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "validate:expo": "npx --yes expo-env-info && npx --yes expo-doctor@latest"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/types": "^7.29.0",
    "@expo/vector-icons": "^15.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.2.0",
    "expo": "~56.0.13",
    "expo-build-properties": "~56.0.20",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.21",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.12",
    "expo-splash-screen": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.15",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": false
      }
    }
  },
  "private": true
}
